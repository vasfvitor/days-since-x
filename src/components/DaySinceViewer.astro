---
import type { DaySinceConfig } from "../lib/types";
import { DEFAULTS, REPO_URL } from "../lib/defaults";
import { prepareView } from "../lib/prepare-view";
import "../styles/viewer.css";

interface Props {
  config: DaySinceConfig;
  hash?: string;
  presetSlug?: string;
}

const { config, hash, presetSlug } = Astro.props;
const { bg, accent, latest, days, record, isRecord, timeline } = prepareView(config, DEFAULTS.lang);
const editUrl = presetSlug
  ? `${REPO_URL}/edit/main/src/data/presets/${presetSlug}.json`
  : hash ? `/?edit=${hash}` : undefined;
---

<div class="ds-root" style={`--bg: ${bg}; --accent: ${accent};`}>
  <div class="ds-lang-corner">
    <div class="lang-switch">
      <button data-lang="pt-BR">PT</button>
      <button data-lang="en">EN</button>
    </div>
  </div>

  <main class="ds-main">
    {latest ? (
      <Fragment>
        <p class="ds-label ds-fade" data-i18n="itHasBeen">Faz</p>
        <p class="ds-number ds-fade" style="animation-delay: 0.1s">
          <span class="ds-count" data-date={latest.date} data-target={days}>0</span>
        </p>
        <p class="ds-unit ds-fade" style="animation-delay: 0.15s">
          <span class="ds-days" data-i18n={days === 1 ? "day" : "days"}>{days === 1 ? "dia" : "dias"}</span>
        </p>
        <p class="ds-since ds-fade" style="animation-delay: 0.2s">
          <span data-i18n="sinceTheLast">desde o último</span>{" "}
          {config.title}.
        </p>
        <p class="ds-latest ds-fade" style="animation-delay: 0.25s">
          <span data-i18n="mostRecent">Mais recente</span>:{" "}
          {latest.url
            ? <a href={latest.url} target="_blank" rel="noopener">{latest.name}</a>
            : <strong>{latest.name}</strong>
          }
          {latest.date && <Fragment> &mdash; <time class="ds-latest-date" data-date={latest.date}>{latest.dateFormatted}</time></Fragment>}
        </p>
        {record > 0 && timeline.length >= 2 && (
          <p class={`ds-record ds-fade ${isRecord ? "ds-record-new" : ""}`} style="animation-delay: 0.3s">
            {isRecord
              ? <Fragment><span data-i18n="newRecord">Novo recorde!</span></Fragment>
              : <Fragment><span data-i18n="record">Nosso recorde é de</span> {record} {record === 1 ? "dia" : "dias"}</Fragment>
            }
          </p>
        )}
      </Fragment>
    ) : (
      <p class="ds-since ds-fade">{config.title}</p>
    )}
  </main>

  {timeline.length > 0 && (
    <section class="ds-timeline ds-fade" style="animation-delay: 0.35s">
      <h2 data-i18n="timeline">Linha do tempo</h2>
      <ul>
        {timeline.map((e, i) => (
          <li class="ds-fade" style={`animation-delay: ${0.4 + i * 0.04}s`}>
            <span class="dot" />
            <div>
              {e.url
                ? <a href={e.url} target="_blank" rel="noopener">{e.name}</a>
                : <strong>{e.name}</strong>
              }
              {e.date && <time data-date={e.date}>{e.dateFormatted}</time>}
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  <footer class="ds-fade" style="animation-delay: 0.5s">
    <a href="/" data-i18n="createYourOwn">Crie o seu</a>
    {editUrl && (
      <Fragment>
        <span class="sep">&middot;</span>
        {presetSlug
          ? <a href={editUrl} target="_blank" rel="noopener" data-i18n="editOnGithub">Editar no GitHub</a>
          : <a href={editUrl} data-i18n="edit">Editar</a>
        }
      </Fragment>
    )}
  </footer>
</div>

<script>
  import { getLang, formatDateLocale } from "../lib/i18n";

  function updateDates() {
    const lang = getLang();
    document.querySelectorAll<HTMLTimeElement>("time[data-date]").forEach((el) => {
      el.textContent = formatDateLocale(el.dataset.date!, lang);
    });
  }

  function countUp() {
    const el = document.querySelector<HTMLSpanElement>(".ds-count");
    if (!el?.dataset.target) return;
    const target = parseInt(el.dataset.target, 10);
    if (isNaN(target) || target <= 0) {
      el.textContent = String(target);
      return;
    }
    const duration = Math.min(1200, 300 + target * 3);
    const start = performance.now();
    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el!.textContent = String(Math.round(eased * target));
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  function updateCounter() {
    const el = document.querySelector<HTMLSpanElement>(".ds-count");
    if (!el?.dataset.date) return;
    const then = new Date(el.dataset.date + "T00:00:00").getTime();
    const days = Math.floor((Date.now() - then) / 86_400_000);
    el.textContent = String(days);
    el.dataset.target = String(days);
  }

  updateDates();
  countUp();
  setInterval(updateCounter, 60_000);
  window.addEventListener("langchange", updateDates);
</script>
