---
import type { DaySinceConfig } from "../lib/types";
import { daysSince } from "../lib/codec";
import { formatDateLocale } from "../lib/i18n";

interface Props {
  config: DaySinceConfig;
  hash?: string;
}

const { config, hash } = Astro.props;
const bg = config.bg ?? "#f0f8ff";
const accent = config.accent ?? "#4444ff";

const withDates = config.entries.filter((e) => e.date);
const sorted = [...withDates].sort(
  (a, b) => new Date(b.date!).getTime() - new Date(a.date!).getTime()
);
const latest = sorted[0];
const days = latest ? daysSince(latest.date!) : 0;

const timeline = [...config.entries].sort((a, b) => {
  if (a.date && b.date) return new Date(a.date).getTime() - new Date(b.date).getTime();
  if (a.date) return -1;
  if (b.date) return 1;
  return 0;
});

const defaultLang = "pt-BR";
---

<div class="ds-root" style={`--bg: ${bg}; --accent: ${accent};`}>
  <main class="ds-main">
    {latest ? (
      <Fragment>
        <p class="ds-label" data-i18n="itHasBeen">Faz</p>
        <p class="ds-number">
          <span class="ds-count" data-date={latest.date}>{days}</span>
        </p>
        <p class="ds-unit">
          <span class="ds-days" data-i18n={days === 1 ? "day" : "days"}>{days === 1 ? "dia" : "dias"}</span>
        </p>
        <p class="ds-since">
          <span data-i18n="sinceTheLast">desde o último</span>{" "}
          {config.title}.
        </p>
        <p class="ds-latest">
          <span data-i18n="mostRecent">Mais recente</span>:{" "}
          {latest.url
            ? <a href={latest.url} target="_blank" rel="noopener">{latest.name}</a>
            : <strong>{latest.name}</strong>
          }
          {latest.date && <Fragment> &mdash; <time class="ds-latest-date" data-date={latest.date}>{formatDateLocale(latest.date, defaultLang)}</time></Fragment>}
        </p>
      </Fragment>
    ) : (
      <p class="ds-since">{config.title}</p>
    )}
  </main>

  {timeline.length > 0 && (
    <section class="ds-timeline">
      <h2 data-i18n="timeline">Linha do tempo</h2>
      <ul>
        {timeline.map((e) => (
          <li>
            <span class="dot" />
            <div>
              {e.url
                ? <a href={e.url} target="_blank" rel="noopener">{e.name}</a>
                : <strong>{e.name}</strong>
              }
              {e.date && <time data-date={e.date}>{formatDateLocale(e.date, defaultLang)}</time>}
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  <footer>
    <a href="/" data-i18n="createYourOwn">Crie o seu</a>
    {hash && (
      <Fragment>
        <span class="sep">&middot;</span>
        <a href={`/?edit=${hash}`} data-i18n="edit">Editar</a>
      </Fragment>
    )}
  </footer>
</div>

<script>
  import { getLang, formatDateLocale } from "../lib/i18n";

  function updateDates() {
    const lang = getLang();
    document.querySelectorAll<HTMLTimeElement>("time[data-date]").forEach((el) => {
      el.textContent = formatDateLocale(el.dataset.date!, lang);
    });
  }

  function updateCounter() {
    const el = document.querySelector<HTMLSpanElement>(".ds-count");
    if (!el?.dataset.date) return;
    const then = new Date(el.dataset.date + "T00:00:00").getTime();
    const days = Math.floor((Date.now() - then) / 86_400_000);
    el.textContent = String(days);
  }

  updateDates();
  updateCounter();
  setInterval(updateCounter, 60_000);
  window.addEventListener("langchange", updateDates);
</script>

<style>
  .ds-root {
    background: var(--bg);
    min-height: 100vh;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem;
    background-image: radial-gradient(circle, rgba(0,0,0,0.03) 1px, transparent 1px);
    background-size: 24px 24px;
  }
  .ds-main {
    max-width: 900px;
    width: 100%;
    text-align: center;
    margin-top: 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }
  .ds-label {
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.5;
    margin-bottom: 0.25rem;
  }
  .ds-number {
    font-size: clamp(5rem, 18vw, 12rem);
    font-weight: 900;
    line-height: 1;
    color: var(--accent);
  }
  .ds-count {
    color: inherit;
  }
  .ds-unit {
    font-size: clamp(1.2rem, 3vw, 2rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.6;
    margin-bottom: 1rem;
  }
  .ds-since {
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    line-height: 1.4;
    max-width: 650px;
    opacity: 0.7;
  }
  .ds-latest {
    margin-top: 2rem;
    font-size: 0.95rem;
    opacity: 0.55;
  }
  .ds-latest a {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ds-timeline {
    margin-top: 5rem;
    max-width: 600px;
    width: 100%;
  }
  .ds-timeline h2 {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.4;
  }
  .ds-timeline ul {
    list-style: none;
    border-left: 2px solid var(--accent);
    margin-left: 0.75rem;
    padding-left: 1.5rem;
  }
  .ds-timeline li {
    position: relative;
    margin-bottom: 1.5rem;
  }
  .dot {
    position: absolute;
    left: -1.82rem;
    top: 0.3rem;
    width: 12px;
    height: 12px;
    background: var(--bg, #f0f8ff);
    border: 2.5px solid var(--accent);
    border-radius: 50%;
  }
  .ds-timeline a,
  .ds-timeline strong {
    font-size: 1rem;
    font-weight: 600;
  }
  .ds-timeline a {
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(0,0,0,0.2);
  }
  .ds-timeline a:hover {
    text-decoration-color: currentColor;
  }
  .ds-timeline time {
    display: block;
    font-size: 0.8rem;
    opacity: 0.45;
    margin-top: 0.1rem;
  }
  footer {
    margin-top: auto;
    padding: 2.5rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    opacity: 0.45;
  }
  footer:hover { opacity: 0.7; }
  footer a {
    text-decoration: none;
  }
  footer a:hover { text-decoration: underline; }
  .sep { opacity: 0.4; }
</style>
