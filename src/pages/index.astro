---
import Base from "../layouts/Base.astro";
import { DEFAULTS } from "../lib/defaults";
import { THEMES } from "../lib/themes";
import { t } from "../lib/i18n";

const lang = DEFAULTS.lang;
const presetFiles = import.meta.glob("../data/presets/*.json", { eager: true });
const presets = Object.entries(presetFiles).map(([path, mod]) => {
  const slug = path.split("/").pop()!.replace(".json", "");
  const data = (mod as any).default;
  return { slug, title: data.title };
});
---

<Base title="Days Since">
  <div class="builder">
    <header class="builder-header">
      <div class="header-row">
        <div>
          <h1>Days Since</h1>
          <p class="subtitle" data-i18n="builderSubtitle">{t(lang, "builderSubtitle")}</p>
        </div>
        <div class="lang-switch">
          <button data-lang="pt-BR">PT</button>
          <button data-lang="en">EN</button>
        </div>
      </div>
    </header>

    {presets.length > 0 && (
      <div class="presets">
        <span class="presets-label" data-i18n="examples">{t(lang, "examples")}</span>
        {presets.map((p) => (
          <a href={`/p/${p.slug}`}>{p.title}</a>
        ))}
      </div>
    )}

    <form id="builder-form">
      <label>
        <span data-i18n="titleLabel">{t(lang, "titleLabel")}</span>
        <input type="text" id="f-title" data-i18n-placeholder="titlePlaceholder" placeholder={t(lang, "titlePlaceholder")} required />
        <p class="title-preview" id="title-preview">
          <span class="preview-muted" data-i18n="itHasBeen">{t(lang, "itHasBeen")}</span>
          {" 42 "}
          <span class="preview-muted" data-i18n="days">{t(lang, "days")}</span>
          {" "}
          <span class="preview-muted" data-i18n="sinceTheLast">{t(lang, "sinceTheLast")}</span>
          {" "}<span id="preview-title" class="preview-title-text"></span>.
        </p>
      </label>

      <div class="theme-section">
        <span class="theme-label" data-i18n="theme">{t(lang, "theme")}</span>
        <div class="theme-grid">
          {THEMES.map((t, i) => (
            <button
              type="button"
              class={`theme-btn ${i === 0 ? "active" : ""}`}
              data-bg={t.bg}
              data-accent={t.accent}
              title={t.name}
            >
              <span class="theme-swatch" style={`background: ${t.bg}; border-color: ${t.accent};`}>
                <span class="theme-accent" style={`background: ${t.accent};`}></span>
              </span>
              <span class="theme-name">{t.name}</span>
            </button>
          ))}
          <button type="button" class="theme-btn theme-custom" id="theme-custom-btn" title="Custom">
            <span class="theme-swatch theme-swatch-custom">
              <span class="theme-accent-custom">?</span>
            </span>
            <span class="theme-name" data-i18n="custom">{t(lang, "custom")}</span>
          </button>
        </div>
        <div id="custom-colors" class="color-row" hidden>
          <label>
            <span data-i18n="background">{t(lang, "background")}</span>
            <div class="color-input">
              <input type="color" id="f-bg" value={DEFAULTS.bg} />
              <span class="color-hex" id="f-bg-hex">{DEFAULTS.bg}</span>
            </div>
          </label>
          <label>
            <span data-i18n="accent">{t(lang, "accent")}</span>
            <div class="color-input">
              <input type="color" id="f-accent" value={DEFAULTS.accent} />
              <span class="color-hex" id="f-accent-hex">{DEFAULTS.accent}</span>
            </div>
          </label>
        </div>
      </div>

      <fieldset id="entries-fieldset">
        <legend data-i18n="entriesLegend">{t(lang, "entriesLegend")}</legend>
        <div class="entries-header">
          <span data-i18n="namePlaceholder">{t(lang, "namePlaceholder")}</span>
          <span data-i18n="urlPlaceholder">{t(lang, "urlPlaceholder")}</span>
          <span data-i18n="datePlaceholder">{t(lang, "datePlaceholder")}</span>
          <span></span>
        </div>
        <div id="entries-list"></div>
        <div class="entries-actions">
          <button type="button" id="add-entry" class="btn-ghost" data-i18n="addEntry">{t(lang, "addEntry")}</button>
          <button type="button" id="toggle-bulk" class="btn-ghost btn-bulk-toggle" data-i18n="importHelp">{t(lang, "importHelp")}</button>
        </div>
        <div id="bulk-wrap" class="bulk-view" hidden>
          <textarea id="bulk-text" rows="5" placeholder="Feather, feather-rs/feather, 2019-09-01&#10;MCHPRS, MCHPR/MCHPRS, 2020-05-01&#10;Valence,, 2022-10-01"></textarea>
        </div>
      </fieldset>

      <button type="submit" class="btn-primary" data-i18n="generateLink">{t(lang, "generateLink")}</button>
    </form>

    <div id="result" class="result" hidden>
      <p class="result-label" data-i18n="yourLink">{t(lang, "yourLink")}</p>
      <div class="result-box">
        <input type="text" id="result-url" readonly />
        <button id="copy-btn" class="btn-copy" data-i18n="copy">{t(lang, "copy")}</button>
      </div>
      <div class="result-actions">
        <a id="open-btn" class="btn-primary btn-open" target="_blank" rel="noopener" data-i18n="open">{t(lang, "open")}</a>
        <a id="permalink-btn" class="btn-ghost btn-permalink" target="_blank" rel="noopener" data-i18n="createPermalink">{t(lang, "createPermalink")}</a>
      </div>
    </div>

    <footer class="builder-footer">
    </footer>
  </div>
</Base>

<script src="../scripts/builder-page.ts"></script>

<style>
  .builder *,
  .builder *::before,
  .builder *::after {
    box-sizing: border-box;
  }
  .builder {
    max-width: 640px;
    width: 100%;
    padding: 3rem 1.5rem 2rem;
    margin: 0 auto;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    box-sizing: border-box;
    font-size: 1.05rem;
  }
  .builder-header {
    margin-bottom: 2.5rem;
  }
  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  h1 {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.4rem;
  }
  .subtitle {
    font-size: 0.88rem;
    opacity: 0.45;
    line-height: 1.55;
    font-weight: 400;
  }
  .presets {
    margin-bottom: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }
  .presets-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.35;
    margin-right: 0.25rem;
  }
  .presets a {
    background: rgba(68,68,255,0.06);
    color: #4444ff;
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    font-size: 0.78rem;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .presets a:hover {
    background: rgba(68,68,255,0.14);
    transform: translateY(-1px);
  }
  form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.01em;
  }
  .title-preview {
    font-size: 0.82rem;
    opacity: 0.4;
    font-weight: 400;
    line-height: 1.5;
    padding: 0.35rem 0;
    display: none;
  }
  .preview-muted {
    opacity: 0.7;
  }
  .preview-title-text {
    font-weight: 700;
    opacity: 1;
    color: var(--c-brand);
  }
  input[type="text"],
  input[type="url"],
  input[type="date"] {
    padding: 0.65rem 0.8rem;
    border: 1.5px solid var(--c-border);
    border-radius: var(--r-sm);
    font-size: 0.92rem;
    font-family: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
    background: #fff;
    max-width: 100%;
    min-width: 0;
  }
  input[type="text"]:focus,
  input[type="url"]:focus,
  input[type="date"]:focus {
    outline: none;
    border-color: var(--c-brand);
    box-shadow: 0 0 0 3px rgba(68,68,255,0.08);
  }
  .theme-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .theme-label {
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.01em;
  }
  .theme-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .theme-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem;
    border: 2px solid transparent;
    border-radius: 10px;
    background: none;
    cursor: pointer;
    transition: all 0.2s;
    min-width: 56px;
    font-family: inherit;
  }
  .theme-btn:hover {
    background: rgba(0,0,0,0.03);
  }
  .theme-btn.active {
    border-color: #1a1a2e;
  }
  .theme-swatch {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1.5px solid #e2e0dd;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 3px;
    transition: transform 0.2s;
  }
  .theme-btn:hover .theme-swatch {
    transform: scale(1.08);
  }
  .theme-accent {
    width: 12px;
    height: 12px;
    border-radius: 4px;
  }
  .theme-swatch-custom {
    background: conic-gradient(from 0deg, #ff6b6b, #ffd93d, #6bcb77, #4d96ff, #9b59b6, #ff6b6b);
    border-color: #ddd;
  }
  .theme-accent-custom {
    font-size: 0.65rem;
    font-weight: 700;
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }
  .theme-name {
    font-size: 0.62rem;
    opacity: 0.45;
    font-weight: 500;
    white-space: nowrap;
  }
  .color-row {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .color-row:not([hidden]) {
    animation: slideDown 0.2s ease;
  }
  .color-row label { flex: 1; }
  .color-input {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  input[type="color"] {
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    width: 42px;
    height: 34px;
    border: 1.5px solid var(--c-border);
    border-radius: var(--r-sm);
    cursor: pointer;
    padding: 3px;
    transition: border-color 0.2s;
    background: none;
  }
  input[type="color"]::-webkit-color-swatch-wrapper {
    padding: 0;
  }
  input[type="color"]::-webkit-color-swatch {
    border: none;
    border-radius: 5px;
  }
  input[type="color"]::-moz-color-swatch {
    border: none;
    border-radius: 5px;
  }
  input[type="color"]:hover {
    border-color: #bbb;
  }
  .color-hex {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    opacity: 0.45;
  }
  fieldset {
    border: 1.5px solid var(--c-border);
    border-radius: var(--r-lg);
    padding: 1rem;
    overflow: hidden;
  }
  legend {
    font-weight: 700;
    font-size: 0.78rem;
    padding: 0 0.3rem;
  }
  .entries-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 0.8fr) 28px;
    gap: 0.4rem;
    margin-bottom: 0.4rem;
    padding: 0 0.1rem;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.3;
  }
  .entries-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  :global(.entry-row) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(0, 0.8fr) 28px;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
    align-items: center;
  }
  @media (max-width: 500px) {
    .builder {
      padding: 2rem 1rem 1.5rem;
    }
    .header-row {
      flex-wrap: wrap;
    }
    .entries-header { display: none; }
    :global(.entry-row) {
      grid-template-columns: 1fr 1fr;
      gap: 0.35rem;
    }
    :global(.entry-row input) {
      min-width: 0;
    }
    :global(.e-date) {
      grid-column: 1 / -1;
    }
    :global(.btn-remove) {
      grid-column: 1 / -1;
      justify-self: end;
    }
    fieldset {
      padding: 0.75rem;
    }
    .theme-grid {
      gap: 0.35rem;
    }
    .theme-btn {
      min-width: 48px;
      padding: 0.3rem;
    }
    .color-row {
      flex-direction: column;
      gap: 0.75rem;
    }
    .btn-primary, .btn-ghost {
      width: 100%;
      box-sizing: border-box;
    }
    .result-box {
      flex-direction: column;
    }
    .result-box input[type="text"] {
      width: 100%;
      min-width: 0;
      box-sizing: border-box;
    }
    .btn-copy {
      width: 100%;
      box-sizing: border-box;
    }
    .result-actions {
      flex-direction: column;
    }
    .result-actions .btn-open,
    .result-actions .btn-permalink {
      width: 100%;
      box-sizing: border-box;
      text-align: center;
    }
    .entries-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .bulk-view textarea {
      font-size: 0.78rem;
    }
  }
  :global(.entry-row input) {
    padding: 0.5rem 0.65rem;
    border: 1.5px solid var(--c-border);
    border-radius: var(--r-sm);
    font-size: 0.85rem;
    font-family: inherit;
    background: #fff;
    transition: border-color 0.2s, box-shadow 0.2s;
    min-width: 0;
    width: 100%;
  }
  :global(.entry-row input:focus) {
    outline: none;
    border-color: #4444ff;
    box-shadow: 0 0 0 3px rgba(68,68,255,0.08);
  }
  :global(.btn-remove) {
    background: none;
    border: none;
    font-size: 1.1rem;
    cursor: pointer;
    opacity: 0.3;
    padding: 0.25rem;
    transition: opacity 0.2s, background 0.2s, color 0.2s;
    line-height: 1;
    border-radius: var(--r-sm);
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  :global(.btn-remove:hover) {
    opacity: 0.8;
    background: rgba(255,0,0,0.06);
    color: #c00;
  }
  .btn-primary, .btn-ghost {
    padding: 0.7rem 1.3rem;
    border-radius: 10px;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    text-decoration: none;
    text-align: center;
    font-family: inherit;
    transition: all 0.2s ease;
  }
  .btn-primary {
    background: #1a1a2e;
    color: white;
  }
  .btn-primary:hover {
    background: #2d2d4e;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(26,26,46,0.2);
  }
  .btn-primary:active {
    transform: translateY(0);
    box-shadow: none;
  }
  .btn-ghost {
    background: transparent;
    color: #4444ff;
    font-size: 0.82rem;
    padding: 0.4rem 0.5rem;
  }
  .btn-ghost:hover {
    background: rgba(68,68,255,0.06);
    border-radius: 8px;
  }
  .btn-bulk-toggle {
    color: rgba(0,0,0,0.35);
    font-size: 0.72rem;
    font-weight: 500;
  }
  .btn-bulk-toggle:hover {
    color: rgba(0,0,0,0.55);
    background: rgba(0,0,0,0.03);
  }
  .bulk-view {
    margin-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .bulk-view:not([hidden]) {
    animation: slideDown 0.2s ease;
  }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .bulk-view textarea {
    padding: 0.6rem 0.7rem;
    border: 1.5px solid #e2e0dd;
    border-radius: 8px;
    font-size: 0.82rem;
    font-family: 'JetBrains Mono', monospace;
    resize: vertical;
    background: #faf9f7;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    line-height: 1.6;
    max-width: 100%;
    width: 100%;
  }
  .bulk-view textarea:focus {
    outline: none;
    border-color: #4444ff;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(68,68,255,0.08);
  }

  /* Result */
  .result {
    margin-top: 2rem;
    padding: 1.5rem;
    border: 1.5px solid #e2e0dd;
    border-radius: 14px;
    background: #faf9f7;
  }
  .result.result-enter {
    animation: resultReveal 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes resultReveal {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  .result-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.35;
    margin-bottom: 0.75rem;
  }
  .result-box {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .result-box input[type="text"] {
    flex: 1;
    padding: 0.55rem 0.7rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    border: 1.5px solid #e2e0dd;
    border-radius: 8px;
    background: #fff;
    color: #333;
  }
  .btn-copy {
    padding: 0.55rem 1rem;
    border-radius: 8px;
    border: 1.5px solid #e2e0dd;
    background: #fff;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .btn-copy:hover { border-color: #999; }
  .btn-copy.copied {
    background: #1a1a2e;
    color: white;
    border-color: #1a1a2e;
  }
  .result-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .btn-open {
    flex: 1;
    display: block;
  }
  .btn-permalink {
    font-size: 0.75rem;
    white-space: nowrap;
    opacity: 0.6;
    text-decoration: none;
  }
  .btn-permalink:hover {
    opacity: 1;
  }

  /* Footer */
  .builder-footer {
    margin-top: auto;
    padding-top: 3rem;
    display: flex;
    justify-content: center;
  }
</style>
