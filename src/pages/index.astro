---
import Base from "../layouts/Base.astro";
import { DEFAULTS } from "../lib/defaults";
import { THEMES } from "../lib/themes";

const presetFiles = import.meta.glob("../data/presets/*.json", { eager: true });
const presets = Object.entries(presetFiles).map(([path, mod]) => {
  const slug = path.split("/").pop()!.replace(".json", "");
  const data = (mod as any).default;
  return { slug, title: data.title };
});
---

<Base title="Days Since">
  <div class="builder">
    <header class="builder-header">
      <div class="header-row">
        <div>
          <h1>Days Since</h1>
          <p class="subtitle" data-i18n="builderSubtitle">Crie um contador "dias desde" compartilhável. Preencha o formulário e pegue seu link.</p>
        </div>
        <div class="lang-switch">
          <button data-lang="pt-BR">PT</button>
          <button data-lang="en">EN</button>
        </div>
      </div>
    </header>

    {presets.length > 0 && (
      <div class="presets">
        <span class="presets-label" data-i18n="examples">Exemplos</span>
        {presets.map((p) => (
          <a href={`/p/${p.slug}`}>{p.title}</a>
        ))}
      </div>
    )}

    <form id="builder-form">
      <label>
        <span data-i18n="titleLabel">Título (o que estamos contando?)</span>
        <input type="text" id="f-title" data-i18n-placeholder="titlePlaceholder" placeholder="novo servidor de Minecraft feito em Rust" required />
      </label>

      <div class="theme-section">
        <span class="theme-label" data-i18n="theme">Tema</span>
        <div class="theme-grid">
          {THEMES.map((t, i) => (
            <button
              type="button"
              class={`theme-btn ${i === 0 ? "active" : ""}`}
              data-bg={t.bg}
              data-accent={t.accent}
              title={t.name}
            >
              <span class="theme-swatch" style={`background: ${t.bg}; border-color: ${t.accent};`}>
                <span class="theme-accent" style={`background: ${t.accent};`}></span>
              </span>
              <span class="theme-name">{t.name}</span>
            </button>
          ))}
          <button type="button" class="theme-btn theme-custom" id="theme-custom-btn" title="Custom">
            <span class="theme-swatch theme-swatch-custom">
              <span class="theme-accent-custom">?</span>
            </span>
            <span class="theme-name" data-i18n="custom">Personalizado</span>
          </button>
        </div>
        <div id="custom-colors" class="color-row" hidden>
          <label>
            <span data-i18n="background">Fundo</span>
            <div class="color-input">
              <input type="color" id="f-bg" value={DEFAULTS.bg} />
              <span class="color-hex" id="f-bg-hex">{DEFAULTS.bg}</span>
            </div>
          </label>
          <label>
            <span data-i18n="accent">Destaque</span>
            <div class="color-input">
              <input type="color" id="f-accent" value={DEFAULTS.accent} />
              <span class="color-hex" id="f-accent-hex">{DEFAULTS.accent}</span>
            </div>
          </label>
        </div>
      </div>

      <fieldset id="entries-fieldset">
        <legend data-i18n="entriesLegend">Entradas (pelo menos uma)</legend>
        <div class="entries-header">
          <span data-i18n="namePlaceholder">Nome</span>
          <span data-i18n="urlPlaceholder">URL ou user/repo</span>
          <span data-i18n="datePlaceholder">Data (opcional)</span>
          <span></span>
        </div>
        <div id="entries-list"></div>
        <div class="entries-actions">
          <button type="button" id="add-entry" class="btn-ghost" data-i18n="addEntry">+ Adicionar entrada</button>
          <button type="button" id="toggle-bulk" class="btn-ghost btn-bulk-toggle" data-i18n="importHelp">Uma entrada por linha: nome, url, data</button>
        </div>
        <div id="bulk-wrap" class="bulk-view" hidden>
          <textarea id="bulk-text" rows="5" placeholder="Feather, feather-rs/feather, 2019-09-01&#10;MCHPRS, MCHPR/MCHPRS, 2020-05-01&#10;Valence,, 2022-10-01"></textarea>
        </div>
      </fieldset>

      <button type="submit" class="btn-primary" data-i18n="generateLink">Gerar link</button>
    </form>

    <div id="result" class="result" hidden>
      <p class="result-label" data-i18n="yourLink">Seu link</p>
      <div class="result-box">
        <input type="text" id="result-url" readonly />
        <button id="copy-btn" class="btn-copy" data-i18n="copy">Copiar</button>
      </div>
      <a id="open-btn" class="btn-primary btn-open" target="_blank" rel="noopener" data-i18n="open">Abrir</a>
    </div>

    <footer class="builder-footer">
    </footer>
  </div>
</Base>

<script>
  import { encode, decode, resolveUrl } from "../lib/codec";
  import { getLang, t } from "../lib/i18n";
  import type { DaySinceConfig, DaySinceEntry } from "../lib/types";

  const list = document.getElementById("entries-list")!;
  const form = document.getElementById("builder-form") as HTMLFormElement;
  const bulkText = document.getElementById("bulk-text") as HTMLTextAreaElement;
  const bulkWrap = document.getElementById("bulk-wrap")!;

  // Color hex display
  const bgInput = document.getElementById("f-bg") as HTMLInputElement;
  const accentInput = document.getElementById("f-accent") as HTMLInputElement;
  const bgHex = document.getElementById("f-bg-hex")!;
  const accentHex = document.getElementById("f-accent-hex")!;
  bgInput.addEventListener("input", () => {
    bgHex.textContent = bgInput.value;
    clearActiveTheme();
  });
  accentInput.addEventListener("input", () => {
    accentHex.textContent = accentInput.value;
    clearActiveTheme();
  });

  // --- Theme picker ---
  const customColorsDiv = document.getElementById("custom-colors")!;
  const themeBtns = document.querySelectorAll<HTMLButtonElement>(".theme-btn:not(.theme-custom)");
  const customBtn = document.getElementById("theme-custom-btn")!;

  function clearActiveTheme() {
    themeBtns.forEach(b => b.classList.remove("active"));
    customBtn.classList.add("active");
    customColorsDiv.hidden = false;
  }

  themeBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      themeBtns.forEach(b => b.classList.remove("active"));
      customBtn.classList.remove("active");
      btn.classList.add("active");
      customColorsDiv.hidden = true;
      const bg = btn.dataset.bg!;
      const accent = btn.dataset.accent!;
      bgInput.value = bg;
      accentInput.value = accent;
      bgHex.textContent = bg;
      accentHex.textContent = accent;
    });
  });

  customBtn.addEventListener("click", () => {
    clearActiveTheme();
    bgInput.focus();
  });

  document.getElementById("toggle-bulk")!.addEventListener("click", () => {
    const isHidden = bulkWrap.hidden;
    bulkWrap.hidden = !isHidden;
    if (isHidden) {
      bulkText.value = rowsToText();
      bulkText.focus();
    }
  });

  // --- Two-way sync between rows and textarea ---
  let syncing = false;

  /** Read all rows → CSV string */
  function rowsToText(): string {
    return [...list.querySelectorAll(".entry-row")]
      .map((row) => {
        const name = (row.querySelector(".e-name") as HTMLInputElement).value;
        const url = (row.querySelector(".e-url") as HTMLInputElement).value;
        const date = (row.querySelector(".e-date") as HTMLInputElement).value;
        if (!name && !url && !date) return "";
        if (date) return `${name}, ${url}, ${date}`;
        if (url) return `${name}, ${url}`;
        return name;
      })
      .filter(Boolean)
      .join("\n");
  }

  /** Sync rows → textarea */
  function syncToTextarea() {
    if (syncing) return;
    syncing = true;
    bulkText.value = rowsToText();
    syncing = false;
  }

  /** Parse CSV text → recreate all rows */
  function syncToRows() {
    if (syncing) return;
    syncing = true;
    const lines = bulkText.value.split("\n");
    list.innerHTML = "";
    let hasContent = false;
    for (const line of lines) {
      const trimmed = line.trim();
      if (!trimmed) continue;
      const parts = trimmed.split(",").map((s) => s.trim());
      createEntryRow(parts[0] || "", parts[1] || "", parts[2] || "");
      hasContent = true;
    }
    if (!hasContent) createEntryRow();
    syncing = false;
  }

  function createEntryRow(name = "", url = "", date = "") {
    const lang = getLang();
    const row = document.createElement("div");
    row.className = "entry-row";
    row.innerHTML = `
      <input type="text" class="e-name" data-i18n-placeholder="namePlaceholder" placeholder="${t(lang, "namePlaceholder")}" value="${name}" required />
      <input type="text" class="e-url" data-i18n-placeholder="urlPlaceholder" placeholder="${t(lang, "urlPlaceholder")}" value="${url}" />
      <input type="date" class="e-date" value="${date}" />
      <button type="button" class="btn-remove" title="Remove">&times;</button>
    `;
    row.querySelectorAll("input").forEach((input) => {
      input.addEventListener("input", syncToTextarea);
    });
    row.querySelector(".btn-remove")!.addEventListener("click", () => {
      if (list.querySelectorAll(".entry-row").length > 1) {
        row.remove();
        syncToTextarea();
      }
    });
    list.appendChild(row);
  }

  document.getElementById("add-entry")!.addEventListener("click", () => {
    createEntryRow();
    syncToTextarea();
  });

  // Textarea input → sync to rows (debounced)
  let debounceTimer: ReturnType<typeof setTimeout>;
  bulkText.addEventListener("input", () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(syncToRows, 400);
  });

  // Pre-fill form if ?edit=HASH is present
  const editHash = new URLSearchParams(window.location.search).get("edit");
  const editConfig = editHash ? decode(editHash) : null;
  if (editConfig) {
    (document.getElementById("f-title") as HTMLInputElement).value = editConfig.title;
    if (editConfig.bg) {
      bgInput.value = editConfig.bg;
      bgHex.textContent = editConfig.bg;
    }
    if (editConfig.accent) {
      accentInput.value = editConfig.accent;
      accentHex.textContent = editConfig.accent;
    }
    for (const entry of editConfig.entries) {
      createEntryRow(entry.name, entry.url ?? "", entry.date ?? "");
    }
  } else {
    createEntryRow();
  }

  // Initial sync: rows → textarea
  syncToTextarea();

  form.addEventListener("submit", (e) => {
    e.preventDefault();

    const entries: DaySinceEntry[] = [...list.querySelectorAll(".entry-row")].map((row) => {
      const rawUrl = (row.querySelector(".e-url") as HTMLInputElement).value;
      const date = (row.querySelector(".e-date") as HTMLInputElement).value;
      return {
        name: (row.querySelector(".e-name") as HTMLInputElement).value,
        url: resolveUrl(rawUrl),
        date: date || undefined,
      };
    });

    if (entries.length === 0) return;

    const config: DaySinceConfig = {
      title: (document.getElementById("f-title") as HTMLInputElement).value,
      bg: bgInput.value,
      accent: accentInput.value,
      entries,
    };

    const hash = encode(config);
    const url = `${window.location.origin}/d#${hash}`;

    const resultDiv = document.getElementById("result")!;
    const resultUrl = document.getElementById("result-url") as HTMLInputElement;
    const openBtn = document.getElementById("open-btn") as HTMLAnchorElement;

    resultUrl.value = url;
    openBtn.href = url;
    resultDiv.hidden = false;
    resultDiv.classList.add("result-enter");
    resultUrl.select();
    resultDiv.scrollIntoView({ behavior: "smooth", block: "nearest" });
  });

  document.getElementById("copy-btn")!.addEventListener("click", () => {
    const lang = getLang();
    const input = document.getElementById("result-url") as HTMLInputElement;
    navigator.clipboard.writeText(input.value);
    const btn = document.getElementById("copy-btn")!;
    btn.textContent = t(lang, "copied");
    btn.classList.add("copied");
    setTimeout(() => {
      btn.textContent = t(lang, "copy");
      btn.classList.remove("copied");
    }, 2000);
  });
</script>

<style>
  .builder {
    max-width: 640px;
    width: 100%;
    padding: 3rem 1.5rem 2rem;
    margin: 0 auto;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  .builder-header {
    margin-bottom: 2.5rem;
  }
  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  h1 {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.4rem;
  }
  .subtitle {
    font-size: 0.88rem;
    opacity: 0.45;
    line-height: 1.55;
    font-weight: 400;
  }
  .presets {
    margin-bottom: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }
  .presets-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.35;
    margin-right: 0.25rem;
  }
  .presets a {
    background: rgba(68,68,255,0.06);
    color: #4444ff;
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    font-size: 0.78rem;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .presets a:hover {
    background: rgba(68,68,255,0.14);
    transform: translateY(-1px);
  }
  form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.01em;
  }
  input[type="text"],
  input[type="url"],
  input[type="date"] {
    padding: 0.65rem 0.8rem;
    border: 1.5px solid #e2e0dd;
    border-radius: 10px;
    font-size: 0.92rem;
    font-family: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
    background: #fff;
  }
  input[type="text"]:focus,
  input[type="url"]:focus,
  input[type="date"]:focus {
    outline: none;
    border-color: #4444ff;
    box-shadow: 0 0 0 3px rgba(68,68,255,0.08);
  }
  .theme-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .theme-label {
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.01em;
  }
  .theme-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .theme-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem;
    border: 2px solid transparent;
    border-radius: 10px;
    background: none;
    cursor: pointer;
    transition: all 0.2s;
    min-width: 56px;
    font-family: inherit;
  }
  .theme-btn:hover {
    background: rgba(0,0,0,0.03);
  }
  .theme-btn.active {
    border-color: #1a1a2e;
  }
  .theme-swatch {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1.5px solid #e2e0dd;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 3px;
    transition: transform 0.2s;
  }
  .theme-btn:hover .theme-swatch {
    transform: scale(1.08);
  }
  .theme-accent {
    width: 12px;
    height: 12px;
    border-radius: 4px;
  }
  .theme-swatch-custom {
    background: conic-gradient(from 0deg, #ff6b6b, #ffd93d, #6bcb77, #4d96ff, #9b59b6, #ff6b6b);
    border-color: #ddd;
  }
  .theme-accent-custom {
    font-size: 0.65rem;
    font-weight: 700;
    color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }
  .theme-name {
    font-size: 0.62rem;
    opacity: 0.45;
    font-weight: 500;
    white-space: nowrap;
  }
  .color-row {
    display: flex;
    gap: 1rem;
    margin-top: 0.25rem;
    animation: slideDown 0.2s ease;
  }
  .color-row label { flex: 1; }
  .color-input {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  input[type="color"] {
    width: 42px;
    height: 34px;
    border: 1.5px solid #e2e0dd;
    border-radius: 8px;
    cursor: pointer;
    padding: 2px;
    transition: border-color 0.2s;
  }
  input[type="color"]:hover {
    border-color: #bbb;
  }
  .color-hex {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    opacity: 0.45;
  }
  fieldset {
    border: 1.5px solid #eae8e5;
    border-radius: 12px;
    padding: 1rem;
  }
  legend {
    font-weight: 700;
    font-size: 0.78rem;
    padding: 0 0.3rem;
  }
  .entries-header {
    display: grid;
    grid-template-columns: 1fr 1fr auto auto;
    gap: 0.4rem;
    margin-bottom: 0.4rem;
    padding: 0 0.1rem;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.3;
  }
  .entries-header span:nth-child(3) {
    min-width: 130px;
  }
  .entries-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  :global(.entry-row) {
    display: grid;
    grid-template-columns: 1fr 1fr auto auto;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
    align-items: center;
  }
  @media (max-width: 500px) {
    .entries-header { display: none; }
    :global(.entry-row) {
      grid-template-columns: 1fr 1fr;
    }
  }
  :global(.entry-row input) {
    padding: 0.5rem 0.65rem;
    border: 1.5px solid #e2e0dd;
    border-radius: 8px;
    font-size: 0.85rem;
    font-family: inherit;
    background: #fff;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  :global(.entry-row input:focus) {
    outline: none;
    border-color: #4444ff;
    box-shadow: 0 0 0 3px rgba(68,68,255,0.08);
  }
  :global(.btn-remove) {
    background: none;
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    opacity: 0.2;
    padding: 0.25rem;
    transition: all 0.2s;
    line-height: 1;
    border-radius: 6px;
  }
  :global(.btn-remove:hover) {
    opacity: 0.7;
    background: rgba(255,0,0,0.06);
    color: #c00;
  }
  .btn-primary, .btn-ghost {
    padding: 0.7rem 1.3rem;
    border-radius: 10px;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    text-decoration: none;
    text-align: center;
    font-family: inherit;
    transition: all 0.2s ease;
  }
  .btn-primary {
    background: #1a1a2e;
    color: white;
  }
  .btn-primary:hover {
    background: #2d2d4e;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(26,26,46,0.2);
  }
  .btn-primary:active {
    transform: translateY(0);
    box-shadow: none;
  }
  .btn-ghost {
    background: transparent;
    color: #4444ff;
    font-size: 0.82rem;
    padding: 0.4rem 0.5rem;
  }
  .btn-ghost:hover {
    background: rgba(68,68,255,0.06);
    border-radius: 8px;
  }
  .btn-bulk-toggle {
    color: rgba(0,0,0,0.35);
    font-size: 0.72rem;
    font-weight: 500;
  }
  .btn-bulk-toggle:hover {
    color: rgba(0,0,0,0.55);
    background: rgba(0,0,0,0.03);
  }
  .bulk-view {
    margin-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    animation: slideDown 0.2s ease;
  }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .bulk-view textarea {
    padding: 0.6rem 0.7rem;
    border: 1.5px solid #e2e0dd;
    border-radius: 8px;
    font-size: 0.82rem;
    font-family: 'JetBrains Mono', monospace;
    resize: vertical;
    background: #faf9f7;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    line-height: 1.6;
  }
  .bulk-view textarea:focus {
    outline: none;
    border-color: #4444ff;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(68,68,255,0.08);
  }

  /* Result */
  .result {
    margin-top: 2rem;
    padding: 1.5rem;
    border: 1.5px solid #e2e0dd;
    border-radius: 14px;
    background: #faf9f7;
  }
  .result.result-enter {
    animation: resultReveal 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes resultReveal {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  .result-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.35;
    margin-bottom: 0.75rem;
  }
  .result-box {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .result-box input[type="text"] {
    flex: 1;
    padding: 0.55rem 0.7rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    border: 1.5px solid #e2e0dd;
    border-radius: 8px;
    background: #fff;
    color: #333;
  }
  .btn-copy {
    padding: 0.55rem 1rem;
    border-radius: 8px;
    border: 1.5px solid #e2e0dd;
    background: #fff;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .btn-copy:hover { border-color: #999; }
  .btn-copy.copied {
    background: #1a1a2e;
    color: white;
    border-color: #1a1a2e;
  }
  .btn-open {
    display: block;
    width: 100%;
  }

  /* Footer */
  .builder-footer {
    margin-top: auto;
    padding-top: 3rem;
    display: flex;
    justify-content: center;
  }
</style>
