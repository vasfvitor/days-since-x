---
import Base from "../layouts/Base.astro";
import "../styles/viewer.css";
---

<Base title="Days Since">
  <div id="loading" class="loading">
    <div class="loading-dot"></div>
    <span data-i18n="loading">Carregando…</span>
  </div>
  <div id="mount"></div>

  <script>
    import { decode } from "../lib/codec";
    import { getLang, t, type Lang } from "../lib/i18n";
    import { prepareView } from "../lib/prepare-view";
    import { REPO_URL } from "../lib/defaults";
    import type { DaySinceConfig } from "../lib/types";

    function el(tag: string, cls?: string, attrs?: Record<string, string>): HTMLElement {
      const e = document.createElement(tag);
      if (cls) e.className = cls;
      if (attrs) for (const [k, v] of Object.entries(attrs)) e.setAttribute(k, v);
      return e;
    }

    function txt(parent: HTMLElement, text: string) {
      parent.appendChild(document.createTextNode(text));
    }

    function fade(e: HTMLElement, delay?: string): HTMLElement {
      e.classList.add("ds-fade");
      if (delay) e.style.animationDelay = delay;
      return e;
    }

    function nameEl(name: string, url: string | undefined): HTMLElement {
      if (url) {
        const a = el("a", undefined, { href: url, target: "_blank", rel: "noopener" });
        a.textContent = name;
        return a;
      }
      const strong = el("strong");
      strong.textContent = name;
      return strong;
    }

    function buildPermalinkUrl(config: DaySinceConfig, hash: string): string {
      const url = `${window.location.origin}/d#${hash}`;
      const issueTitle = `[counter] ${config.title}`;
      const entriesTable = config.entries
        .map(e => `| ${e.name} | ${e.url ?? ""} | ${e.date ?? ""} |`)
        .join("\n");
      const issueBody = [
        `## ${config.title}`,
        "",
        `**Link:** [View counter](${url})`,
        "",
        `| Name | URL | Date |`,
        `|------|-----|------|`,
        entriesTable,
        "",
        `<details><summary>Raw config</summary>`,
        "",
        "```json",
        JSON.stringify(config, null, 2),
        "```",
        "</details>",
      ].join("\n");
      return `${REPO_URL}/issues/new?title=${encodeURIComponent(issueTitle)}&body=${encodeURIComponent(issueBody)}`;
    }

    function countUp(target: number, element: HTMLElement) {
      if (target <= 0) { element.textContent = String(target); return; }
      const duration = Math.min(1200, 300 + target * 3);
      const start = performance.now();
      function tick(now: number) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        element.textContent = String(Math.round(eased * target));
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    function showLoading(msg: string, linkText: string) {
      const loading = document.getElementById("loading")!;
      loading.textContent = "";
      const span = el("span");
      span.textContent = msg;
      loading.appendChild(span);
      const a = el("a", "loading-link", { href: "/" });
      a.textContent = linkText;
      loading.appendChild(a);
    }

    function render(config: DaySinceConfig, lang: Lang, hash: string) {
      const { bg, accent, textColor, latest, days, record, isRecord, timeline } = prepareView(config, lang);
      const mount = document.getElementById("mount")!;
      mount.textContent = "";

      const root = el("div", "ds-root");
      root.style.setProperty("--bg", bg);
      root.style.setProperty("--accent", accent);
      root.style.setProperty("--text", textColor);

      // Lang switch
      const langCorner = el("div", "ds-lang-corner");
      const langSwitch = el("div", "lang-switch");
      const btnPt = el("button", undefined, { "data-lang": "pt-BR" });
      btnPt.textContent = "PT";
      const btnEn = el("button", undefined, { "data-lang": "en" });
      btnEn.textContent = "EN";
      langSwitch.append(btnPt, btnEn);
      langCorner.appendChild(langSwitch);
      root.appendChild(langCorner);

      // Main
      const main = el("main", "ds-main");

      if (latest) {
        // Label
        const label = fade(el("p", "ds-label", { "data-i18n": "itHasBeen" }));
        label.textContent = t(lang, "itHasBeen");
        main.appendChild(label);

        // Number
        const numP = fade(el("p", "ds-number"), "0.1s");
        const countSpan = el("span", "ds-count");
        countSpan.dataset.date = latest.date ?? "";
        countSpan.dataset.target = String(days);
        countSpan.textContent = "0";
        numP.appendChild(countSpan);
        main.appendChild(numP);

        // Unit
        const unitP = fade(el("p", "ds-unit"), "0.15s");
        const dayKey = days === 1 ? "day" : "days";
        const daySpan = el("span", "ds-days", { "data-i18n": dayKey });
        daySpan.textContent = t(lang, dayKey);
        unitP.appendChild(daySpan);
        main.appendChild(unitP);

        // Since
        const sinceP = fade(el("p", "ds-since"), "0.2s");
        const sinceSpan = el("span", undefined, { "data-i18n": "sinceTheLast" });
        sinceSpan.textContent = t(lang, "sinceTheLast");
        sinceP.appendChild(sinceSpan);
        txt(sinceP, ` ${config.title}.`);
        main.appendChild(sinceP);

        // Latest
        const latestP = fade(el("p", "ds-latest"), "0.25s");
        const recSpan = el("span", undefined, { "data-i18n": "mostRecent" });
        recSpan.textContent = t(lang, "mostRecent");
        latestP.appendChild(recSpan);
        txt(latestP, ": ");
        latestP.appendChild(nameEl(latest.name, latest.url));
        if (latest.date) {
          txt(latestP, " \u2014 ");
          const time = el("time", "ds-latest-date", { "data-date": latest.date });
          time.textContent = latest.dateFormatted ?? "";
          latestP.appendChild(time);
        }
        main.appendChild(latestP);

        // Record
        if (record > 0 && timeline.length >= 2) {
          const recP = fade(el("p", `ds-record${isRecord ? " ds-record-new" : ""}`), "0.3s");
          if (isRecord) {
            const s = el("span", undefined, { "data-i18n": "newRecord" });
            s.textContent = t(lang, "newRecord");
            recP.appendChild(s);
          } else {
            const s = el("span", undefined, { "data-i18n": "record" });
            s.textContent = t(lang, "record");
            recP.appendChild(s);
            txt(recP, ` ${record} ${record === 1 ? t(lang, "day") : t(lang, "days")}`);
          }
          main.appendChild(recP);
        }
      } else {
        const sinceP = fade(el("p", "ds-since"));
        sinceP.textContent = config.title;
        main.appendChild(sinceP);
      }

      root.appendChild(main);

      // Timeline
      if (timeline.length > 0) {
        const section = fade(el("section", "ds-timeline"), "0.35s");
        const h2 = el("h2", undefined, { "data-i18n": "timeline" });
        h2.textContent = t(lang, "timeline");
        section.appendChild(h2);

        const ul = el("ul");
        timeline.forEach((e, i) => {
          const li = fade(el("li"), `${0.4 + i * 0.04}s`);
          li.appendChild(el("span", "dot"));
          const div = el("div");
          div.appendChild(nameEl(e.name, e.url));
          if (e.date) {
            const time = el("time", undefined, { "data-date": e.date });
            time.textContent = e.dateFormatted ?? "";
            div.appendChild(time);
          }
          li.appendChild(div);
          ul.appendChild(li);
        });
        section.appendChild(ul);
        root.appendChild(section);
      }

      // Footer
      const footer = fade(el("footer"), "0.5s");
      const createLink = el("a", undefined, { href: "/", "data-i18n": "createYourOwn" });
      createLink.textContent = t(lang, "createYourOwn");
      footer.appendChild(createLink);

      const sep1 = el("span", "sep");
      sep1.textContent = "\u00B7";
      footer.appendChild(sep1);

      const editLink = el("a", undefined, { href: `/?edit=${encodeURIComponent(hash)}`, "data-i18n": "edit" });
      editLink.textContent = t(lang, "edit");
      footer.appendChild(editLink);

      const sep2 = el("span", "sep");
      sep2.textContent = "\u00B7";
      footer.appendChild(sep2);

      const permaLink = el("a", undefined, {
        href: buildPermalinkUrl(config, hash),
        target: "_blank",
        rel: "noopener",
        "data-i18n": "createPermalink",
      });
      permaLink.textContent = t(lang, "createPermalink");
      footer.appendChild(permaLink);

      root.appendChild(footer);
      mount.appendChild(root);

      // Count-up animation
      const countEl = mount.querySelector<HTMLSpanElement>(".ds-count");
      if (countEl?.dataset.target) {
        countUp(parseInt(countEl.dataset.target, 10), countEl);
      }

      document.title = latest
        ? `${days} ${t(lang, days === 1 ? "day" : "days")} - ${config.title} | Days Since`
        : `${config.title} | Days Since`;
    }

    let currentConfig: DaySinceConfig | null = null;
    let currentHash = "";

    function init() {
      const hash = window.location.hash.slice(1);
      const lang = getLang();

      if (!hash) {
        showLoading(t(lang, "noData"), t(lang, "goToBuilder"));
        return;
      }

      const config = decode(hash);
      if (!config) {
        showLoading(t(lang, "couldNotDecode"), t(lang, "goToBuilder"));
        return;
      }

      currentConfig = config;
      currentHash = hash;
      document.getElementById("loading")!.style.display = "none";
      render(config, lang, hash);
    }

    init();
    window.addEventListener("hashchange", init);
    window.addEventListener("langchange", () => {
      if (currentConfig) {
        render(currentConfig, getLang(), currentHash);
      }
    });
  </script>
</Base>

<style is:global>
  #mount {
    width: 100%;
  }
  .loading {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    min-height: 100vh;
    font-size: 0.95rem;
    opacity: 0.4;
    text-align: center;
    gap: 1rem;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.3); opacity: 0.6; }
  }
  .loading-dot {
    width: 8px;
    height: 8px;
    background: currentColor;
    border-radius: 50%;
    animation: pulse 1.2s ease-in-out infinite;
  }
  .loading-link {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.4rem 0.8rem;
    font-size: 0.82rem;
    border: 1.5px solid rgba(0,0,0,0.12);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
  }
  .loading-link:hover {
    border-color: rgba(0,0,0,0.3);
    background: rgba(0,0,0,0.03);
  }
</style>
