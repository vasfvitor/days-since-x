---
import Base from "../layouts/Base.astro";
---

<Base title="Days Since">
  <div id="loading" class="loading" data-i18n="loading">Carregando…</div>
  <div id="mount"></div>

  <script>
    import { decode } from "../lib/codec";
    import { getLang, t, type Lang } from "../lib/i18n";
    import { prepareView } from "../lib/prepare-view";
    import type { DaySinceConfig } from "../lib/types";

    function escHtml(s: string) {
      return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    function render(config: DaySinceConfig, lang: Lang, hash: string) {
      const { bg, accent, latest, days, timeline } = prepareView(config, lang);

      const mount = document.getElementById("mount")!;
      mount.innerHTML = `
        <div class="ds-root" style="--bg: ${bg}; --accent: ${accent};">
          <main class="ds-main">
            ${latest ? `
              <p class="ds-label" data-i18n="itHasBeen">${t(lang, "itHasBeen")}</p>
              <p class="ds-number">
                <span class="ds-count" data-date="${latest.date}">${days}</span>
              </p>
              <p class="ds-unit">
                <span data-i18n="${days === 1 ? "day" : "days"}">${days === 1 ? t(lang, "day") : t(lang, "days")}</span>
              </p>
              <p class="ds-since">
                <span data-i18n="sinceTheLast">${t(lang, "sinceTheLast")}</span>
                ${escHtml(config.title)}.
              </p>
              <p class="ds-latest">
                <span data-i18n="mostRecent">${t(lang, "mostRecent")}</span>:
                ${latest.url
                  ? `<a href="${escHtml(latest.url)}" target="_blank" rel="noopener">${escHtml(latest.name)}</a>`
                  : `<strong>${escHtml(latest.name)}</strong>`}
                ${latest.date ? ` &mdash; <time class="ds-latest-date" data-date="${latest.date}">${latest.dateFormatted}</time>` : ""}
              </p>
            ` : `<p class="ds-since">${escHtml(config.title)}</p>`}
          </main>
          ${timeline.length > 0 ? `
          <section class="ds-timeline">
            <h2 data-i18n="timeline">${t(lang, "timeline")}</h2>
            <ul>
              ${timeline.map(e => `
                <li>
                  <span class="dot"></span>
                  <div>
                    ${e.url
                      ? `<a href="${escHtml(e.url)}" target="_blank" rel="noopener">${escHtml(e.name)}</a>`
                      : `<strong>${escHtml(e.name)}</strong>`}
                    ${e.date ? `<time data-date="${e.date}">${e.dateFormatted}</time>` : ""}
                  </div>
                </li>
              `).join("")}
            </ul>
          </section>` : ""}
          <footer>
            <a href="/" data-i18n="createYourOwn">${t(lang, "createYourOwn")}</a>
            <span class="sep">&middot;</span>
            <a href="/?edit=${encodeURIComponent(hash)}" data-i18n="edit">${t(lang, "edit")}</a>
          </footer>
        </div>
      `;

      document.title = latest
        ? `${days} ${t(lang, days === 1 ? "day" : "days")} - ${config.title}`
        : config.title;
    }

    let currentConfig: DaySinceConfig | null = null;
    let currentHash = "";

    function init() {
      const hash = window.location.hash.slice(1);
      const loading = document.getElementById("loading")!;
      const lang = getLang();

      if (!hash) {
        loading.innerHTML = `${t(lang, "noData")}<br><a href="/">${t(lang, "goToBuilder")}</a>`;
        return;
      }

      const config = decode(hash);
      if (!config) {
        loading.innerHTML = `${t(lang, "couldNotDecode")}<br><a href="/">${t(lang, "goToBuilder")}</a>`;
        return;
      }

      currentConfig = config;
      currentHash = hash;
      loading.style.display = "none";
      render(config, lang, hash);
    }

    init();
    window.addEventListener("hashchange", init);
    window.addEventListener("langchange", () => {
      if (currentConfig) {
        render(currentConfig, getLang(), currentHash);
      }
    });
  </script>
</Base>

<style is:global>
  .loading {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    min-height: 100vh;
    font-size: 1.1rem;
    opacity: 0.4;
    text-align: center;
    gap: 0.5rem;
  }
  .ds-root {
    background: var(--bg);
    min-height: 100vh;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem;
    background-image: radial-gradient(circle, rgba(0,0,0,0.03) 1px, transparent 1px);
    background-size: 24px 24px;
  }
  .ds-main {
    max-width: 900px;
    width: 100%;
    text-align: center;
    margin-top: 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .ds-label {
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.5;
    margin-bottom: 0.25rem;
  }
  .ds-number {
    font-size: clamp(5rem, 18vw, 12rem);
    font-weight: 900;
    line-height: 1;
    color: var(--accent);
  }
  .ds-unit {
    font-size: clamp(1.2rem, 3vw, 2rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.6;
    margin-bottom: 1rem;
  }
  .ds-since {
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    line-height: 1.4;
    max-width: 650px;
    opacity: 0.7;
  }
  .ds-latest {
    margin-top: 2rem;
    font-size: 0.95rem;
    opacity: 0.55;
  }
  .ds-latest a {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ds-timeline {
    margin-top: 5rem;
    max-width: 600px;
    width: 100%;
  }
  .ds-timeline h2 {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.4;
  }
  .ds-timeline ul {
    list-style: none;
    border-left: 2px solid var(--accent);
    margin-left: 0.75rem;
    padding-left: 1.5rem;
  }
  .ds-timeline li {
    position: relative;
    margin-bottom: 1.5rem;
  }
  .dot {
    position: absolute;
    left: -1.82rem;
    top: 0.3rem;
    width: 12px;
    height: 12px;
    background: var(--bg, #f0f8ff);
    border: 2.5px solid var(--accent);
    border-radius: 50%;
  }
  .ds-timeline a,
  .ds-timeline strong {
    font-size: 1rem;
    font-weight: 600;
  }
  .ds-timeline a {
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(0,0,0,0.2);
  }
  .ds-timeline a:hover {
    text-decoration-color: currentColor;
  }
  .ds-timeline time {
    display: block;
    font-size: 0.8rem;
    opacity: 0.45;
    margin-top: 0.1rem;
  }
  .ds-root footer {
    margin-top: auto;
    padding: 2.5rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    opacity: 0.45;
  }
  .ds-root footer:hover { opacity: 0.7; }
  .ds-root footer a { text-decoration: none; }
  .ds-root footer a:hover { text-decoration: underline; }
  .sep { opacity: 0.4; }
</style>
