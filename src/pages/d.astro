---
import Base from "../layouts/Base.astro";
---

<Base title="Days Since">
  <div id="loading" class="loading">
    <div class="loading-dot"></div>
    <span data-i18n="loading">Carregando…</span>
  </div>
  <div id="mount"></div>

  <script>
    import { decode } from "../lib/codec";
    import { getLang, t, type Lang } from "../lib/i18n";
    import { prepareView } from "../lib/prepare-view";
    import type { DaySinceConfig } from "../lib/types";

    function escHtml(s: string) {
      return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    function countUp(el: HTMLElement, target: number) {
      if (target <= 0) { el.textContent = String(target); return; }
      const duration = Math.min(1200, 300 + target * 3);
      const start = performance.now();
      function tick(now: number) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = String(Math.round(eased * target));
        if (progress < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    function render(config: DaySinceConfig, lang: Lang, hash: string) {
      const { bg, accent, latest, days, timeline } = prepareView(config, lang);

      const mount = document.getElementById("mount")!;
      mount.innerHTML = `
        <div class="ds-root" style="--bg: ${bg}; --accent: ${accent};">
          <div class="ds-lang-corner">
            <div class="lang-switch">
              <button data-lang="pt-BR">PT</button>
              <button data-lang="en">EN</button>
            </div>
          </div>
          <main class="ds-main">
            ${latest ? `
              <p class="ds-label ds-fade" data-i18n="itHasBeen">${t(lang, "itHasBeen")}</p>
              <p class="ds-number ds-fade" style="animation-delay: 0.1s">
                <span class="ds-count" data-date="${latest.date}" data-target="${days}">0</span>
              </p>
              <p class="ds-unit ds-fade" style="animation-delay: 0.15s">
                <span data-i18n="${days === 1 ? "day" : "days"}">${days === 1 ? t(lang, "day") : t(lang, "days")}</span>
              </p>
              <p class="ds-since ds-fade" style="animation-delay: 0.2s">
                <span data-i18n="sinceTheLast">${t(lang, "sinceTheLast")}</span>
                ${escHtml(config.title)}.
              </p>
              <p class="ds-latest ds-fade" style="animation-delay: 0.25s">
                <span data-i18n="mostRecent">${t(lang, "mostRecent")}</span>:
                ${latest.url
                  ? `<a href="${escHtml(latest.url)}" target="_blank" rel="noopener">${escHtml(latest.name)}</a>`
                  : `<strong>${escHtml(latest.name)}</strong>`}
                ${latest.date ? ` &mdash; <time class="ds-latest-date" data-date="${latest.date}">${latest.dateFormatted}</time>` : ""}
              </p>
            ` : `<p class="ds-since ds-fade">${escHtml(config.title)}</p>`}
          </main>
          ${timeline.length > 0 ? `
          <section class="ds-timeline ds-fade" style="animation-delay: 0.35s">
            <h2 data-i18n="timeline">${t(lang, "timeline")}</h2>
            <ul>
              ${timeline.map((e, i) => `
                <li class="ds-fade" style="animation-delay: ${0.4 + i * 0.04}s">
                  <span class="dot"></span>
                  <div>
                    ${e.url
                      ? `<a href="${escHtml(e.url)}" target="_blank" rel="noopener">${escHtml(e.name)}</a>`
                      : `<strong>${escHtml(e.name)}</strong>`}
                    ${e.date ? `<time data-date="${e.date}">${e.dateFormatted}</time>` : ""}
                  </div>
                </li>
              `).join("")}
            </ul>
          </section>` : ""}
          <footer class="ds-fade" style="animation-delay: 0.5s">
            <a href="/" data-i18n="createYourOwn">${t(lang, "createYourOwn")}</a>
            <span class="sep">&middot;</span>
            <a href="/?edit=${encodeURIComponent(hash)}" data-i18n="edit">${t(lang, "edit")}</a>
          </footer>
        </div>
      `;

      const countEl = mount.querySelector<HTMLSpanElement>(".ds-count");
      if (countEl?.dataset.target) {
        countUp(countEl, parseInt(countEl.dataset.target, 10));
      }

      document.title = latest
        ? `${days} ${t(lang, days === 1 ? "day" : "days")} - ${config.title}`
        : config.title;
    }

    let currentConfig: DaySinceConfig | null = null;
    let currentHash = "";

    function init() {
      const hash = window.location.hash.slice(1);
      const loading = document.getElementById("loading")!;
      const lang = getLang();

      if (!hash) {
        loading.innerHTML = `<span>${t(lang, "noData")}</span><a href="/" class="loading-link">${t(lang, "goToBuilder")}</a>`;
        return;
      }

      const config = decode(hash);
      if (!config) {
        loading.innerHTML = `<span>${t(lang, "couldNotDecode")}</span><a href="/" class="loading-link">${t(lang, "goToBuilder")}</a>`;
        return;
      }

      currentConfig = config;
      currentHash = hash;
      loading.style.display = "none";
      render(config, lang, hash);
    }

    init();
    window.addEventListener("hashchange", init);
    window.addEventListener("langchange", () => {
      if (currentConfig) {
        render(currentConfig, getLang(), currentHash);
      }
    });
  </script>
</Base>

<style is:global>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .ds-fade {
    opacity: 0;
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  #mount {
    width: 100%;
  }
  .loading {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    min-height: 100vh;
    font-size: 0.95rem;
    opacity: 0.4;
    text-align: center;
    gap: 1rem;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.3); opacity: 0.6; }
  }
  .loading-dot {
    width: 8px;
    height: 8px;
    background: currentColor;
    border-radius: 50%;
    animation: pulse 1.2s ease-in-out infinite;
  }
  .loading-link {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.4rem 0.8rem;
    font-size: 0.82rem;
    border: 1.5px solid rgba(0,0,0,0.12);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
  }
  .loading-link:hover {
    border-color: rgba(0,0,0,0.3);
    background: rgba(0,0,0,0.03);
  }
  .ds-root {
    background: var(--bg);
    min-height: 100vh;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem;
    position: relative;
    background-image: radial-gradient(circle, rgba(0,0,0,0.025) 1px, transparent 1px);
    background-size: 28px 28px;
  }
  .ds-lang-corner {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
  }
  .ds-main {
    max-width: 900px;
    width: 100%;
    text-align: center;
    margin-top: 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .ds-label {
    font-size: clamp(0.9rem, 2.5vw, 1.3rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    opacity: 0.4;
    margin-bottom: 0.25rem;
  }
  .ds-number {
    font-size: clamp(5rem, 20vw, 14rem);
    font-weight: 900;
    line-height: 1;
    color: var(--accent);
    letter-spacing: -0.03em;
  }
  .ds-count {
    font-variant-numeric: tabular-nums;
  }
  .ds-unit {
    font-size: clamp(1.1rem, 3vw, 1.8rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    opacity: 0.5;
    margin-bottom: 1.25rem;
  }
  .ds-since {
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    line-height: 1.5;
    max-width: 600px;
    opacity: 0.6;
    font-weight: 400;
  }
  .ds-latest {
    margin-top: 2rem;
    font-size: 0.9rem;
    opacity: 0.45;
  }
  .ds-latest a {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1.5px;
    text-decoration-color: rgba(0,0,0,0.2);
    transition: text-decoration-color 0.2s;
  }
  .ds-latest a:hover {
    text-decoration-color: currentColor;
  }
  .ds-timeline {
    margin-top: 5rem;
    max-width: 560px;
    width: 100%;
  }
  .ds-timeline h2 {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    opacity: 0.3;
  }
  .ds-timeline ul {
    list-style: none;
    border-left: 2px solid var(--accent);
    margin-left: 0.75rem;
    padding-left: 1.5rem;
  }
  .ds-timeline li {
    position: relative;
    margin-bottom: 1.5rem;
    padding: 0.35rem 0.5rem;
    border-radius: 8px;
    transition: background 0.2s;
  }
  .ds-timeline li:hover {
    background: rgba(0,0,0,0.02);
  }
  .dot {
    position: absolute;
    left: -1.82rem;
    top: 0.65rem;
    width: 10px;
    height: 10px;
    background: var(--bg);
    border: 2.5px solid var(--accent);
    border-radius: 50%;
    transition: transform 0.2s, background 0.2s;
  }
  .ds-timeline li:hover .dot {
    transform: scale(1.3);
    background: var(--accent);
  }
  .ds-timeline a,
  .ds-timeline strong {
    font-size: 0.95rem;
    font-weight: 600;
  }
  .ds-timeline a {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(0,0,0,0.15);
    transition: text-decoration-color 0.2s;
  }
  .ds-timeline a:hover {
    text-decoration-color: currentColor;
  }
  .ds-timeline time {
    display: block;
    font-size: 0.78rem;
    opacity: 0.4;
    margin-top: 0.15rem;
  }
  .ds-root footer {
    margin-top: auto;
    padding: 2.5rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.78rem;
    opacity: 0.35;
    transition: opacity 0.2s;
  }
  .ds-root footer:hover { opacity: 0.65; }
  .ds-root footer a { text-decoration: none; }
  .ds-root footer a:hover { text-decoration: underline; }
  .sep { opacity: 0.4; }
</style>
